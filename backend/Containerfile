FROM ghcr.io/astral-sh/uv:python3.12-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    gdal-bin libgdal-dev libgeos-dev libproj-dev postgresql \
    && rm -rf /var/lib/apt/lists/*

# Non-root default user. At runtime the UID is typically overridden to the host
# user (see docker-compose) so files written to mounted volumes stay host-owned.
RUN groupadd --gid 1000 app && useradd --uid 1000 --gid 1000 --create-home app

# uv cache and Python bytecode go to /tmp so any runtime UID can write there
ENV UV_CACHE_DIR=/tmp/.uv-cache \
    UV_NO_SYNC=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app
RUN chown app:app /app
USER app

# Copy workspace root pyproject.toml and lockfile first
COPY --chown=app:app pyproject.toml uv.lock ./
COPY --chown=app:app backend/pyproject.toml backend/

# Install dependencies (without the project itself)
RUN uv sync --frozen --no-install-project --package geoquery-backend

# Copy backend source
COPY --chown=app:app backend/ backend/
RUN uv sync --frozen --package geoquery-backend \
    && chmod -R a+rX /app \
    && rm -rf /tmp/.uv-cache

WORKDIR /app/backend

# Collect static files (admin CSS/JS, etc.) for WhiteNoise to serve. Uses a
# throwaway secret key since collectstatic needs settings to load but no DB.
RUN DJANGO_SECRET_KEY=collectstatic-build-only \
    uv run python manage.py collectstatic --noinput
