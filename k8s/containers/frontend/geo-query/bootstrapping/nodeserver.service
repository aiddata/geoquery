[Service]
ExecStart=/bin/sh -c '/usr/local/bin/supervisor -w WEB_DIR/routes,WEB_DIR/server.js WEB_DIR/server.js >> /var/log/nodeserver.sys.log 2>&1'
ExecStartPre=/bin/sh -c 'echo "[`date -u +%Y-%m-%dT%T.%3NZ`] (sys) Starting" >> /var/log/nodeserver.sys.log'
Restart=always
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=nodeserver
User=aiddata
Group=aiddata
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
