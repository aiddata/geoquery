          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  search_date,\n  COUNT(requests.id) AS request_count\nFROM\n  (\n    SELECT\n      DATE(now()) - sequential_dates AS search_date\n    FROM\n      generate_series(29, 0, -1) AS sequential_dates\n  )\nLEFT JOIN requests ON DATE(requests.submit_time) = search_date\n\nGROUP BY search_date\nORDER BY search_date asc;",
          "refId": "A",
          "sql": {
